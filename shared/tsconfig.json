{
    "extends": "../tsconfig.json",
    "compilerOptions": {
      "composite": false,
      "declaration": true,
      "declarationMap": true,
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "jsx": "react-jsx",
      "skipLibCheck": true
    },
    "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"]
}
